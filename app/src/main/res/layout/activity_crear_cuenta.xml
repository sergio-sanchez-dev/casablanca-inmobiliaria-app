<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/crearCard"
        android:orientation="vertical"
        android:layout_centerInParent="true"
        android:layout_margin="24dp"
        android:background="@drawable/login_card"
        android:elevation="8dp"
        android:padding="24dp">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/log"/>

        <TextView
            android:text="Crear Cuenta"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#8B6B00"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etTelefono"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:hint="Número de teléfono"
            android:padding="12dp"
            android:background="@drawable/login_input"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="Contraseña"
            android:inputType="textPassword"
            android:padding="12dp"
            android:background="@drawable/login_input"
            android:drawableEnd="@drawable/ic_eye"
            android:drawablePadding="10dp"/>

        <EditText
            android:id="@+id/etConfirmar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:hint="Confirmar contraseña"
            android:inputType="textPassword"
            android:padding="12dp"
            android:background="@drawable/login_input"
            android:drawableEnd="@drawable/ic_eye"
            android:drawablePadding="10dp"/>

        <CheckBox
            android:id="@+id/checkPolitica"
            android:text="Aceptar política de privacidad"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnRegistrar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Registrarse"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:layout_marginTop="15dp"
            android:backgroundTint="#C9A227"/>

        <TextView
            android:id="@+id/txtLogin"
            android:text="¿Ya tienes cuenta? Iniciar sesión"
            android:textColor="#1976D2"
            android:layout_marginTop="10dp"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</RelativeLayout>